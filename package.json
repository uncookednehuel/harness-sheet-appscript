{
  "name": "harness-sheets-appscript",
  "version": "0.0.0",
  "description": "",
  "main": "build/index.js",
  "license": "Apache-2.0",
  "keywords": [],
  "scripts": {
    "clean": "rimraf build dist",
    "licenseadd": "npm run license",
    "lint": "eslint --fix --no-error-on-unmatched-pattern src/ test/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "bundle": "rollup --no-treeshake -c rollup.config.mjs",
    "build": "npm run clean && npm run bundle && node scripts/build-index.mjs && ncp appsscript.json dist/appsscript.json",
    "license": "license-check-and-add add -f license-config.json",
    "test": "jest test/ --passWithNoTests --detectOpenHandles",
    "deploy": "npm run build && ncp .clasp-dev.json .clasp.json && clasp push -f",
    "deploy:prod": "npm run lint && npm run test && npm run build && ncp .clasp-prod.json .clasp.json && clasp push"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@google/clasp": "^3.2.0",
    "@types/google-apps-script": "^2.0.8",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "gts": "^7.0.0",
    "jest": "^30.2.0",
    "license-check-and-add": "^4.0.5",
    "ncp": "^2.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.57.1",
    "rollup-plugin-cleanup": "^3.2.1",
    "rollup-plugin-license": "^3.7.0",
    "rollup-plugin-prettier": "^4.1.2",
    "rollup-plugin-typescript2": "^0.36.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^10.0.1",
    "globals": "^17.3.0"
  }
}
